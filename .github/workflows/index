      max-width: 900px; 
      margin: 0 auto; 
      padding: 40px 20px; 
      background: #000000; 
      color: #ffffff; 
      line-height: 1.6;
    }
    
    /* LOGO CONTAINER */
    .logo-container { 
      text-align: center; 
      margin: 50px 0 30px 0; 
    }
    
    /* HEADINGS */
    h1 { 
      color: #ffd700; 
      text-align: center; 
      font-weight: 300; 
      letter-spacing: 6px; 
      font-size: 2.2em;
      margin: 30px 0 10px 0;
      text-transform: uppercase;
    }
    
    h2 { 
      color: #ffffff; 
      text-align: center; 
      font-weight: 300; 
      font-size: 1.1em;
      letter-spacing: 3px;
      margin-bottom: 40px;
    }
    
    h3 { 
      color: #ffd700; 
      font-weight: 400; 
      letter-spacing: 2px;
      font-size: 1em;
      text-transform: uppercase;
      margin: 30px 0 15px 0;
    }
    
    /* TAGLINE */
    .tagline { 
      text-align: center; 
      color: #666666; 
      font-style: italic; 
      font-size: 14px;
      letter-spacing: 2px;
      margin: 15px 0;
    }
    
    /* CONFIDENTIAL BADGE */
    .confidential { 
      text-align: center; 
      color: #ffd700; 
      font-size: 11px; 
      letter-spacing: 4px; 
      margin: 40px 0 30px 0; 
      text-transform: uppercase;
      padding: 10px 0;
      border-top: 1px solid #222;
      border-bottom: 1px solid #222;
    }
    
    /* FEATURE CARDS */
    .features { 
      display: grid; 
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); 
      gap: 25px; 
      margin: 40px 0; 
    }
    
    .feature { 
      background: #0a0a0a; 
      padding: 30px; 
      border: 1px solid #222222;
      transition: all 0.3s ease;
    }
    
    .feature:hover {
      border-color: #ffd700;
      transform: translateY(-3px);
    }
    
    .feature h3 { 
      color: #ffffff; 
      margin-top: 0; 
      font-size: 1.1em;
    }
    
    .feature p { 
      color: #888888; 
      line-height: 1.8; 
      font-size: 14px;
    }
    
    /* DEMO BOX */
    .demo-box { 
      background: #0a0a0a; 
      color: #ffd700; 
      padding: 30px; 
      border: 1px solid #ffd700; 
      font-family: 'Courier New', 'Consolas', monospace; 
      font-size: 13px;
      margin: 30px 0; 
      line-height: 2;
    }
    
    .demo-box p { margin: 8px 0; }
    
    /* CAPITAL BOX */
    .capital-box {
      border: 2px solid #ffd700;
      background: #0a0a0a;
      padding: 30px;
    }
    
    .capital-box .amount {
      font-size: 1.6em; 
      color: #ffd700; 
      font-weight: bold; 
      margin: 15px 0;
    }
    
    .capital-box .subtitle {
      color: #ffffff; 
      margin: 15px 0;
      letter-spacing: 1px;
    }
    
    .capital-box .details {
      color: #888888;
      margin: 15px 0;
      line-height: 1.8;
    }
    
    .capital-box strong {
      color: #ffd700;
    }
    
    /* CTA BUTTON */
    .cta { 
      text-align: center; 
      margin: 50px 0 30px 0; 
    }
    
    button { 
      background: #ffd700; 
      color: #000000; 
      padding: 20px 50px; 
      border: none; 
      font-size: 14px; 
      cursor: pointer; 
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      transition: all 0.3s ease;
    }
    
    button:hover { 
      background: #ffffff; 
      transform: scale(1.05);
    }
    
    /* FOOTER */
    .footer {
      text-align: center; 
      color: #444444; 
      margin-top: 60px; 
      padding-top: 40px;
      border-top: 1px solid #222222;
      font-size: 12px;
      letter-spacing: 1px;
    }
    
    .footer p { margin: 8px 0; }
  </style>
</head>
